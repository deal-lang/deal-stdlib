    attribute si_I  : Integer = 0;
    attribute si_TH : Integer = 0;
    attribute si_N  : Integer = 0;
    attribute si_J  : Integer = 0;
}

/** KinematicViscosity — L^2*T^-1. SI unit: m^2/s. */
attribute def KinematicViscosity {
